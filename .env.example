# Database
DATABASE_URL="postgresql://kredit:kredit_dev@localhost:5432/kredit_dev"

# Auth (Better Auth handles sessions with cookies)
# JWT settings are kept for backwards compatibility but not used for main auth
BETTER_AUTH_SECRET="dev-secret-change-in-production-32-chars-min"

# Storage (local or s3)
STORAGE_TYPE="local"
STORAGE_PATH="./uploads"

# Optional: MinIO (S3-compatible)
# S3_ENDPOINT="http://localhost:9000"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_BUCKET="kredit-uploads"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Notifications (optional for local dev)
# RESEND_API_KEY=""
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
