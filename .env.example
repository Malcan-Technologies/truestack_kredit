# Database
DATABASE_URL="postgresql://kredit:kredit_dev@localhost:5432/kredit_dev"

# Auth (Better Auth handles sessions with cookies)
# JWT settings are kept for backwards compatibility but not used for main auth
BETTER_AUTH_SECRET="dev-secret-change-in-production-32-chars-min"
JWT_SECRET="dev-secret-change-in-production-32-chars-minimum"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-32-chars-minimum"
WEBHOOK_SECRET="dev-webhook-secret-change-in-production-32-chars-minimum"

# Storage (local or s3)
STORAGE_TYPE="local"
STORAGE_PATH="./uploads"
UPLOAD_BASE_URL="/uploads"
AWS_REGION="ap-southeast-5"

# Optional for local: MinIO (S3-compatible)
# S3_ENDPOINT="http://localhost:9000"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_BUCKET="kredit-uploads"

# Production S3 (ECS task role recommended: do NOT set access key/secret)
# STORAGE_TYPE="s3"
# S3_BUCKET="truekredit-uploads-prod"
# AWS_REGION="ap-southeast-5"
# If using non-AWS S3 endpoint in production, set:
# S3_ENDPOINT=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
PROD_DEMO_OWNER_EMAIL="admin@demo.com"
PROD_DEMO_OWNER_NAME="Demo Owner"

# Notifications (optional for local dev)
# RESEND_API_KEY=""
# RESEND_WEBHOOK_SECRET=""
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""

# TrueIdentity / TrueStack Admin integration
# TRUEIDENTITY_ADMIN_BASE_URL="https://admin.truestack.my"
# KREDIT_TRUESTACK_WEBHOOK_SECRET="shared-secret-for-signing-kredit-to-admin-requests"
# TRUEIDENTITY_WEBHOOK_SHARED_SECRET="shared-secret-for-admin-callback-validation"
# TRUEIDENTITY_TIMESTAMP_MAX_AGE_MS="300000"
