# TrueKredit Pro admin — targets backend_pro (same-origin /api/proxy to BACKEND_URL)
# Copy to .env and adjust for local or deployment.

# Public URL of this Next app (Better Auth client baseURL)
NEXT_PUBLIC_APP_URL=http://localhost:3005

# Optional: comma-separated hostnames that may show the public marketing landing at `/`.
# Defaults to demo-admin.truestack.my. Set empty to disable the landing for all hosts.
# Add localhost here if you need to work on the landing page locally.
# NEXT_PUBLIC_LANDING_PAGE_HOSTS=demo-admin.truestack.my

# Local dev only: do not require passkey or authenticator (TOTP) before using the dashboard.
# Leave unset or false in production.
# NEXT_PUBLIC_SKIP_SECURITY_SETUP_REDIRECT=true

# Pro UI: skip SaaS billing add-on gates for TrueIdentity / borrower list (must match server PRODUCT_MODE=pro)
NEXT_PUBLIC_PRODUCT_MODE=pro

# backend_pro base URL (no /api suffix — proxy forwards to BACKEND_URL/api/...)
BACKEND_URL=http://localhost:4001

# Optional: direct API origin if any code calls NEXT_PUBLIC_API_URL (prefer proxy for cookies)
NEXT_PUBLIC_API_URL=http://localhost:4001

# Must match backend_pro BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=dev-secret-change-in-production-32-chars-minimum

# Prisma — same DB as backend_pro if Next routes use Prisma (register/auth)
DATABASE_URL=postgresql://kredit_pro:kredit_pro_dev@localhost:5434/kredit_pro_dev

# Storage / images (match backend_pro)
S3_BUCKET=truekredit-uploads-prod
AWS_REGION=ap-southeast-5

# Email (optional — password reset, etc.)
# RESEND_API_KEY=
# EMAIL_FROM_NAME=TrueKredit
# EMAIL_FROM_ADDRESS=kredit-no-reply@send.truestack.my
