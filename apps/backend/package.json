    "pdfkit": "^0.17.2",
    "svix": "^1.84.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.4",
