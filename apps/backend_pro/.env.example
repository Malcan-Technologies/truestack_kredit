# Database (Pro - port 5434)
DATABASE_URL="postgresql://kredit_pro:kredit_pro_dev@localhost:5434/kredit_pro_dev"

# Better Auth (must match borrower_pro BETTER_AUTH_SECRET)
BETTER_AUTH_SECRET="dev-secret-change-in-production-32-chars-minimum"

# Server
PORT=4001
NODE_ENV=development

# CORS — browser origins allowed to call this API (admin + borrower apps)
CORS_ORIGINS="http://localhost:3005,http://localhost:3006"

# --- Better Auth (shared with admin_pro + borrower_pro/Demo_Client) ---
# Same BETTER_AUTH_SECRET on all apps; sessions live in this DB.
#
# baseURL: Better Auth requires exactly ONE canonical URL on the server. Use either:
#   BETTER_AUTH_BASE_URL  (preferred), or
#   FRONTEND_URL            (legacy alias)
# Point it at your primary public URL in prod (e.g. https://admin.example.com).
#
# trustedOrigins: EVERY origin where users log in (admin + borrower). Comma-separated:
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3005,http://localhost:3006"
#
# If unset, local http://localhost:3005 and :3006 are still included in code so both apps work.
# Optional legacy single-URL alias (used when BETTER_AUTH_BASE_URL is not set):
# FRONTEND_URL="http://localhost:3005"

# Pro deployment: use public TrueStack KYC for staff /borrowers/:id/verify/start (no TrueStack Admin add-on)
PRODUCT_MODE=pro

# Storage
STORAGE_TYPE="local"
STORAGE_PATH="./uploads"

# --- Optional: Google Calendar + Meet (borrower attestation scheduling) ---
# Create a service account in Google Cloud (IAM), create a JSON key, then enable the API:
# APIs & Services → Library → "Google Calendar API" → Enable (required or requests return 403).
# GOOGLE_SERVICE_ACCOUNT_EMAIL must be the SA address ending in .iam.gserviceaccount.com — NOT a personal Gmail.
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Primary calendar for that SA, or a calendar ID shared with the SA (Calendar settings → Share):
# GOOGLE_CALENDAR_ID="calendar-bot@project-id.iam.gserviceaccount.com"
#
# Optional: only for Google Workspace — domain-wide delegation to act as a staff mailbox.
# Do NOT set this to a consumer @gmail.com address (you will get invalid_grant / account not found).
# GOOGLE_CALENDAR_IMPERSONATE_USER="staff@your-workspace-domain.com"

# TrueStack public KYC API (Bearer key from Admin client — not TrueKredit↔Admin HMAC flow)
# TRUESTACK_KYC_API_BASE_URL="https://api.truestack.my"
# TRUESTACK_KYC_API_KEY=""
# Public origin TrueStack can reach for webhooks (use ngrok in local dev). Must be a full URL with scheme, no path suffix (path /api/webhooks/truestack-kyc is appended). Avoid stray spaces or quotes in .env.
# TRUESTACK_KYC_PUBLIC_WEBHOOK_BASE_URL=https://your-tunnel.example.ngrok-free.app
# Optional: redirect user after KYC (webhooks remain authoritative)
# TRUESTACK_KYC_REDIRECT_URL="http://localhost:3006/dashboard/profile"
# Optional: when TrueStack documents X-Webhook-Signature algorithm, wire verification here
# TRUESTACK_KYC_WEBHOOK_SECRET=""
