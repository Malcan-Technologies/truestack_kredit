// TrueKredit Pro - Prisma Schema
// Multi-tenant KPKT loan management (Pro: licensed tenants have full product access; no SaaS subscription billing)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum TenantType {
  PPW // Pemberi Pinjam Wang (Money Lender)
  PPG // Pemberi Pajak Gadai (Pawnbroker)
}

// UserRole is now stored as string for Better Auth compatibility
// Valid values: OWNER, ADMIN, STAFF

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  /// L1 approved; awaiting L2 final decision (loan not created until L2 approves)
  PENDING_L2_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanStatus {
  /// Online applications only: borrower must complete attestation before agreement signing / disbursement prep
  PENDING_ATTESTATION
  PENDING_DISBURSEMENT
  ACTIVE
  IN_ARREARS // Loan has overdue payments past arrearsPeriod
  COMPLETED
  DEFAULTED
  WRITTEN_OFF
  CANCELLED // Borrower withdrew or loan cancelled before disbursement (e.g. after attestation)
}

/** Admin review of borrower-uploaded signed loan agreement before disbursement */
enum SignedAgreementReviewStatus {
  NONE // No signed file, or not applicable yet
  PENDING // Uploaded; awaiting admin approval
  APPROVED
  REJECTED
}

/** Borrower attestation (video and/or online lawyer meeting) before agreement signing */
enum AttestationStatus {
  NOT_STARTED
  VIDEO_COMPLETED // Video watched; borrower may proceed or request a meeting
  MEETING_REQUESTED // Wants a meeting; pick a slot from availability
  SLOT_PROPOSED // Borrower picked a slot; firm DB hold; awaiting admin (12h)
  COUNTER_PROPOSED // Admin countered with a different slot; borrower must accept/decline
  PROPOSAL_EXPIRED // Hold expired; borrower can propose again (transient UI state, often cleared to MEETING_REQUESTED)
  MEETING_SCHEDULED // Admin accepted; Google Calendar + Meet created
  COMPLETED // Attestation done (video-only or post-meeting)
}

/** Who proposed the current attestation meeting slot */
enum AttestationProposalSource {
  BORROWER
  ADMIN_COUNTER
}

/** Why attestation/loan was cancelled from borrower side */
enum AttestationCancellationReason {
  WITHDRAWN
  REJECTED_AFTER_ATTESTATION
  PROPOSAL_REJECTED_BY_LENDER
  /** Legacy: loan cancelled when proposal expired (older behaviour). No longer set by cron. */
  PROPOSAL_DEADLINE_EXPIRED
}

enum RepaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED // Repayment cancelled due to early settlement
}

enum InterestModel {
  FLAT
  RULE_78
  DECLINING_BALANCE
  EFFECTIVE_RATE
}

/** Online vs in-branch / physical loan handling (attestation and ops) */
enum LoanChannel {
  ONLINE
  PHYSICAL
}

enum EventStatus {
  PENDING
  SENT
  FAILED
}

enum BorrowerManualPaymentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BorrowerEarlySettlementRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanApplicationOfferParty {
  ADMIN
  BORROWER
}

enum LoanApplicationOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  SUPERSEDED
}

// ============================================
// Core Tenant Models
// ============================================

model Tenant {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  type               TenantType // PPW (Money Lender) or PPG (Pawnbroker)
  licenseNumber      String? // KPKT license number (e.g., PPW/KL/2024/001)
  registrationNumber String? // Company registration number (SSM)
  email              String? // Company email
  contactNumber      String? // Company contact number
  businessAddress    String? // Company business address
  logoUrl            String? // Company logo URL (local path in dev, S3 in prod)
  /// Malaysian bank code from lender settings (see admin bank-options); use OTHER + lenderBankOtherName for custom
  lenderBankCode          String?
  lenderBankOtherName     String?
  lenderAccountHolderName String?
  lenderAccountNumber     String?
  status             TenantStatus @default(ACTIVE)
  /// When this tenant was granted TrueKredit Pro (purchase or ops). Full product access from this point.
  proLicenseActivatedAt DateTime @default(now())
  /// TrueSend email reminder / late-notice day configuration (JSON). Pro includes TrueSend; no separate add-on row.
  truesendSettings       Json?
  /// Fallback office hours when Google Calendar free/busy is unavailable. JSON: { weekdays: number[], start: "HH:mm", end: "HH:mm", slotStepMinutes: 30, slotDurationMinutes: 60 }
  attestationOfficeHoursJson Json?
  trueIdentityTenantSyncedAt DateTime? // When Admin tenant-created webhook was first sent
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  members              TenantMember[]
  borrowers            Borrower[]
  applicationGuarantors ApplicationGuarantor[]
  loanGuarantors       LoanGuarantor[]
  borrowerDocuments    BorrowerDocument[]
  products             Product[]
  applications         LoanApplication[]
  loanApplicationOffers LoanApplicationOffer[]
  applicationDocuments ApplicationDocument[]
  loans                Loan[]
  auditLogs            AuditLog[]
  files                File[]
  notifications        Notification[]
  outboxEvents         OutboxEvent[]
  sessions             Session[] // Sessions with this tenant active
  adminAuditLogs       AdminAuditLog[] // Admin actions audit trail
  paymentTransactions  PaymentTransaction[] // Payment transactions with receipts
  lateFeeEntries       LateFeeEntry[] // Daily late fee accrual entries
  emailLogs            EmailLog[] // TrueSend email delivery logs
  tenantNotificationSettings TenantNotificationSetting[]
  borrowerNotifications      BorrowerNotification[]
  borrowerNotificationDeliveries BorrowerNotificationDelivery[]
  borrowerPushDevices        BorrowerPushDevice[]
  notificationCampaigns      NotificationCampaign[]
  borrowerPerformanceProjections BorrowerPerformanceProjection[]
  trueIdentitySessions TrueIdentitySession[]
  trueIdentityWebhookEvents TrueIdentityWebhookEvent[]
  trueIdentityUsageDaily TrueIdentityUsageDaily[]
  borrowerProfileLinks       BorrowerProfileLink[]
  borrowerOrganizationLinks  BorrowerOrganizationLink[]
  truestackKycSessions       TruestackKycSession[]
  borrowerManualPaymentRequests BorrowerManualPaymentRequest[]
  borrowerEarlySettlementRequests BorrowerEarlySettlementRequest[]
  borrowerNotes                  BorrowerNote[]
  applicationNotes               ApplicationNote[]
  loanNotes                      LoanNote[]
  staffSigningProfiles           StaffSigningProfile[]
  staffDocuments                 StaffDocument[]
  staffKycSessions               StaffKycSession[]
  loanInternalSignatures         LoanInternalSignature[]
  roles                          TenantRole[]
}

// ============================================
// Better Auth Models
// ============================================

// User model (Better Auth compatible - identity only, no tenant binding)
// role/banned are required by Better Auth admin plugin; tenant-level role is in TenantMember
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  referralCode  String?  @unique
  // Referral payout bank details (user-level, not borrower/tenant-level)
  referralBankAccountName String?
  referralBankName        String?
  referralBankNameOther   String?
  referralBankAccountNo   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth admin plugin fields (app-level; tenant role is in TenantMember)
  role   String  @default("staff")
  banned Boolean @default(false)
  twoFactorEnabled Boolean @default(false)

  // User-level settings
  isActive          Boolean   @default(true)
  passwordChangedAt DateTime?

  // Better Auth relations
  sessions Session[]
  accounts Account[]
  twoFactors TwoFactor[]
  passkeys Passkey[]

  // Better Auth organization plugin (borrower company members)
  members Member[]
  sentInvitations Invitation[] @relation("InvitationInviter")

  // Borrower profile links (self-service: user can act as linked borrowers)
  borrowerProfileLinks BorrowerProfileLink[]

  // Multi-tenant membership
  memberships TenantMember[]

  // Application relations (user-scoped, not tenant-scoped)
  adminAuditLogs AdminAuditLog[]

  // Referral: who invited this user (set at signup when valid referral code is used)
  referredById   String?
  referrer       User?    @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referredUsers  User[]   @relation("UserReferrals")

  // Referral relations (profile-level, not tenant-level)
  referralsGiven   Referral[] @relation("Referrer")
  referralReceived Referral?  @relation("Referred")

  // PKI signing profile and internal signatures
  staffSigningProfiles  StaffSigningProfile[]
  loanInternalSignatures LoanInternalSignature[]
  borrowerPushDevices    BorrowerPushDevice[]

  @@index([email])
  @@index([referralCode])
  @@index([referredById])
}

// Referral - Profile-to-profile referral tracking with eligibility and payout status
model Referral {
  id              String   @id @default(cuid())
  
  // Referral details
  referralCode    String   // The code that was used (6 alphanumeric)
  rewardAmount    Int      // Stored in cents (RM499 = 49900)
  
  // User relationships (profile-to-profile)
  referrerUserId  String
  referredUserId  String   @unique // One referral per profile
  
  // Eligibility and payout tracking
  isEligible      Boolean  @default(false) // Eligible per referral program rules (e.g. after qualifying purchase)
  isPaid          Boolean  @default(false)
  
  eligibleAt      DateTime @default(now())  // Set when referral is created
  paidAt          DateTime?                 // Set when marked as paid
  
  // Relations
  referrer        User     @relation("Referrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referredUser    User     @relation("Referred", fields: [referredUserId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([referrerUserId])
  @@index([referralCode])
  @@index([isEligible, isPaid])
}

// TenantMember - Junction table for multi-tenant access
// One user can belong to multiple tenants with different roles
model TenantMember {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  roleId    String?
  role      String   @default("GENERAL_STAFF") // OWNER or tenant role key
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleConfig TenantRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  auditLogs AuditLog[]
  loansAttestationAssigned Loan[] @relation("AttestationAssignedMember")
  authoredBorrowerNotes     BorrowerNote[]
  authoredApplicationNotes  ApplicationNote[]
  authoredLoanNotes         LoanNote[]

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([roleId])
}

model TenantRole {
  id          String   @id @default(cuid())
  tenantId    String
  key         String
  name        String
  description String?
  permissions String[] @default([])
  isSystem    Boolean  @default(false)
  isEditable  Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members  TenantMember[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

// Session model (Better Auth with active tenant and active borrower)
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Active tenant for this session
  activeTenantId String?
  // Active borrower profile for borrower_pro self-service
  activeBorrowerId String?
  // Better Auth organization plugin: active company (borrower) org
  activeOrganizationId String?
  /// Better Auth organization plugin: team/workspace session field (may mirror org in single-team setups)
  activeTeamId String?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeTenant  Tenant?   @relation(fields: [activeTenantId], references: [id], onDelete: SetNull)
  activeBorrower Borrower? @relation(fields: [activeBorrowerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([token])
  @@index([activeTenantId])
  @@index([activeBorrowerId])
  @@index([activeOrganizationId])
  @@index([activeTeamId])
}

// Account model (Better Auth - for OAuth providers)
model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String? // For credential provider
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// BorrowerProfileLink - links User to Borrower for self-service borrower_pro
// One user can have at most one INDIVIDUAL borrower per tenant; multiple CORPORATE allowed
model BorrowerProfileLink {
  id          String   @id @default(cuid())
  userId      String
  borrowerId  String
  tenantId    String
  borrowerType String  // INDIVIDUAL, CORPORATE (denormalized from Borrower for quick filtering)
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, borrowerId])
  @@index([userId])
  @@index([tenantId])
  @@index([borrowerId])
}

// Better Auth organization plugin (borrower company; 1 org per corporate Borrower)
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  String?

  members      Member[]
  invitations  Invitation[]
  borrowerLink BorrowerOrganizationLink?

  @@map("organization")
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  inviterId      String
  /// "email" | "open_link" — open_link uses synthetic email until bind-open-invitation runs
  inviteKind     String   @default("email")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

/// 1:1 corporate Borrower ↔ Better Auth organization (pro tenant)
model BorrowerOrganizationLink {
  id             String   @id @default(cuid())
  borrowerId     String   @unique
  organizationId String   @unique
  tenantId       String
  createdAt      DateTime @default(now())

  borrower     Borrower     @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Verification model (Better Auth - for email verification, password reset)
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model TwoFactor {
  id          String @id @default(cuid())
  userId      String
  secret      String
  backupCodes String
  verified    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
}

model Passkey {
  id           String   @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime @default(now())
  aaguid       String?
  rpId         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialID])
}

// Admin audit log for tracking admin actions (login, user management, etc.)
model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  action     String // e.g., 'LOGIN', 'USER_ACTIVATED', 'USER_DEACTIVATED', 'USER_ROLE_CHANGED', 'USER_INVITED'
  targetId   String? // ID of the affected entity (e.g., user being modified)
  targetType String? // Type of target (e.g., 'USER', 'TENANT')
  details    String? // Additional details as JSON string
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId, createdAt])
  @@index([action])
}

// ============================================
// Loan Models
// ============================================

model Borrower {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  icNumber  String // IC or Passport number (for individuals) or SSM number (for corporates)
  phone     String?
  email     String?
  address   String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postcode     String?
  country      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Borrower type
  borrowerType String @default("INDIVIDUAL") // INDIVIDUAL, CORPORATE

  // Document verification fields
  documentType     String    @default("IC") // IC, PASSPORT
  documentVerified Boolean   @default(false) // For e-KYC integration
  verifiedAt       DateTime? // When verification was completed
  verifiedBy       String? // e-KYC provider or manual verification

  // Cached overall verification status (FULLY_VERIFIED, PARTIALLY_VERIFIED, UNVERIFIED) - single source of truth, updated by webhook
  verificationStatus         String?   // FULLY_VERIFIED, PARTIALLY_VERIFIED, UNVERIFIED

  // TrueIdentity verification snapshot (updated from Admin webhooks)
  trueIdentityStatus         String?   // pending, processing, completed, expired, failed
  trueIdentityResult         String?   // approved, rejected (when status=completed)
  trueIdentitySessionId      String?   // Admin/Innovatif session id
  trueIdentityOnboardingUrl  String?   // URL for QR / copy-link
  trueIdentityExpiresAt      DateTime? // Session expiry
  trueIdentityLastWebhookAt  DateTime? // Last callback processed
  trueIdentityRejectMessage  String?   // Rejection reason when result=rejected

  // Compliance fields (mandatory for regulatory reporting - Individual borrowers)
  dateOfBirth      DateTime? // Extracted from IC or manually entered for passport holders
  gender           String? // MALE, FEMALE
  race             String? // MELAYU, CINA, INDIA, LAIN_LAIN, BUMIPUTRA_SABAH_SARAWAK, BUKAN_WARGANEGARA
  educationLevel   String? // NO_FORMAL, PRIMARY, SECONDARY, DIPLOMA, DEGREE, POSTGRADUATE
  occupation       String?
  employmentStatus String? // EMPLOYED, SELF_EMPLOYED, UNEMPLOYED, RETIRED, STUDENT
  bankName         String? // Bank code (MAYBANK, CIMB, etc.) or OTHER
  bankNameOther    String? // Custom bank name when bankName is OTHER
  bankAccountNo    String?

  // Non-mandatory fields (Individual borrowers)
  emergencyContactName         String?
  emergencyContactPhone        String?
  emergencyContactRelationship String?
  monthlyIncome                Decimal? @db.Decimal(12, 2)

  // Optional social media profile links
  instagram  String?
  tiktok     String?
  facebook   String?
  linkedin   String?
  xTwitter   String?

  // Corporate fields (required when borrowerType is CORPORATE)
  companyName       String? // Trading/business name
  ssmRegistrationNo String? // SSM registration number
  businessAddress   String? // Registered business address
  authorizedRepName String? // Authorized representative name
  authorizedRepIc   String? // Authorized rep IC number
  companyPhone      String? // Company contact number
  companyEmail      String? // Company email
  natureOfBusiness  String? // Industry/business type
  bumiStatus        String? // BUMI, BUKAN_BUMI, ASING - Taraf for Lampiran A compliance

  // Optional corporate fields
  dateOfIncorporation DateTime? // Company incorporation date
  paidUpCapital       Decimal?  @db.Decimal(14, 2) // Paid-up capital
  numberOfEmployees   Int? // Employee count

  // Relations
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrowerProfileLinks BorrowerProfileLink[]
  borrowerOrganizationLink BorrowerOrganizationLink?
  sessionsAsActive     Session[]   // Sessions with this borrower as active
  applications LoanApplication[]
  applicationGuarantors ApplicationGuarantor[]
  loans        Loan[]
  loanGuarantors LoanGuarantor[]
  borrowerManualPaymentRequests BorrowerManualPaymentRequest[]
  borrowerEarlySettlementRequests BorrowerEarlySettlementRequest[]
  documents    BorrowerDocument[]
  directors    BorrowerDirector[]
  emailLogs    EmailLog[] // TrueSend email delivery logs
  notifications BorrowerNotification[]
  notificationDeliveries BorrowerNotificationDelivery[]
  pushDevices   BorrowerPushDevice[]
  performanceProjection BorrowerPerformanceProjection?
  trueIdentitySessions TrueIdentitySession[]
  truestackKycSessions TruestackKycSession[]
  staffNotes           BorrowerNote[]

  @@unique([tenantId, icNumber])
  @@index([tenantId])
  @@index([borrowerType])
  @@index([borrowerType, icNumber])
  @@index([borrowerType, ssmRegistrationNo])
}

model BorrowerPerformanceProjection {
  id                     String    @id @default(cuid())
  tenantId               String
  borrowerId             String    @unique
  riskLevel              String    @default("NO_HISTORY") // NO_HISTORY, GOOD, WATCH, HIGH_RISK, DEFAULTED
  onTimeRate             Decimal?  @db.Decimal(5, 2) // Borrower-level on-time payment rate (%)
  tags                   String[]  @default([])
  totalLoans             Int       @default(0)
  activeLoans            Int       @default(0)
  inArrearsLoans         Int       @default(0)
  defaultedLoans         Int       @default(0)
  completedLoans         Int       @default(0)
  writtenOffLoans        Int       @default(0)
  pendingDisbursementLoans Int     @default(0)
  readyForDefaultLoans   Int       @default(0)
  paidOnTimeCount        Int       @default(0)
  paidLateCount          Int       @default(0)
  overdueCount           Int       @default(0)
  lastPaymentAt          DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([riskLevel])
  @@index([onTimeRate])
}

model BorrowerDirector {
  id         String   @id @default(cuid())
  borrowerId String
  name       String
  icNumber   String
  position   String?
  order      Int      @default(0)
  /// Exactly one director per corporate borrower should be true (authorized signatory for KYC + agreement).
  isAuthorizedRepresentative Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // TrueIdentity verification (per-director KYC)
  trueIdentityStatus        String?   // pending, processing, completed, expired, failed
  trueIdentityResult        String?   // approved, rejected (when status=completed)
  trueIdentitySessionId    String?   // Admin/Innovatif session id
  trueIdentityOnboardingUrl String?  // URL for QR / copy-link
  trueIdentityExpiresAt     DateTime? // Session expiry
  trueIdentityLastWebhookAt DateTime? // Last callback processed
  trueIdentityRejectMessage String?   // Rejection reason when result=rejected
  trueIdentityDocumentUrls  Json?     // { icFrontUrl?, icBackUrl?, selfieUrl?, verificationDetailUrl?, updatedAt? } from Admin

  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  truestackKycSessions TruestackKycSession[]

  @@index([borrowerId])
}

// TrueStack public KYC API sessions (Bearer ti_/ts_ keys) — not Admin HMAC TrueIdentity
model TruestackKycSession {
  id                String   @id @default(cuid())
  tenantId          String
  borrowerId        String
  directorId        String?
  externalSessionId String   @unique // UUID from TrueStack POST /api/v1/kyc/sessions
  onboardingUrl     String
  expiresAt         DateTime?
  status            String   @default("pending") // pending, processing, completed, expired, failed
  result            String? // approved, rejected when status=completed
  rejectMessage     String?
  lastWebhookAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower Borrower          @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  director BorrowerDirector? @relation(fields: [directorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([borrowerId])
  @@index([borrowerId, directorId])
}

model Product {
  id              String        @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  interestModel   InterestModel @default(FLAT)
  interestRate    Decimal       @default(18.00) @db.Decimal(5, 2) // Annual interest rate (e.g., 18.00%)
  latePaymentRate Decimal       @default(8.00) @db.Decimal(5, 2) // Annual late payment interest rate
  arrearsPeriod   Int           @default(14) // Days after missed payment before loan is at risk (triggers notifications)
  defaultPeriod   Int           @default(28) // Days after missed payment before loan is considered defaulted
  minAmount       Decimal       @db.Decimal(12, 2)
  maxAmount       Decimal       @db.Decimal(12, 2)
  minTerm         Int // in months
  maxTerm         Int // in months
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Fee configuration
  legalFeeType     String  @default("FIXED") // FIXED or PERCENTAGE
  legalFeeValue    Decimal @default(0) @db.Decimal(12, 2)
  stampingFeeType  String  @default("FIXED") // FIXED or PERCENTAGE
  stampingFeeValue Decimal @default(0) @db.Decimal(12, 2)

  // Required documents - tenant-configurable categories
  // JSON array of { key: string, label: string, required: boolean }
  requiredDocuments Json @default("[]")

  // Borrower eligibility - which types of borrowers can use this product
  // Valid values: INDIVIDUAL, CORPORATE, BOTH
  eligibleBorrowerTypes String @default("BOTH")

  // Loan schedule type per KPKT regulations
  // JADUAL_J = No collateral, JADUAL_K = With collateral (12% max rate)
  loanScheduleType String @default("JADUAL_J")

  // Early settlement configuration
  earlySettlementEnabled       Boolean @default(false)
  earlySettlementLockInMonths  Int     @default(0) // 0 = no lock-in period
  earlySettlementDiscountType  String  @default("PERCENTAGE") // PERCENTAGE or FIXED
  earlySettlementDiscountValue Decimal @default(0) @db.Decimal(12, 2) // % of remaining interest or RM amount

  // Relations
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications LoanApplication[]
  loans        Loan[]

  @@index([tenantId])
}

model LoanApplication {
  id         String            @id @default(cuid())
  tenantId   String
  borrowerId String
  productId  String
  amount     Decimal           @db.Decimal(12, 2)
  term       Int // in months
  status     ApplicationStatus @default(DRAFT)
  notes      String?
  actualInterestRate Decimal?  @db.Decimal(5, 2) // Optional internal schedule annual rate captured during raising
  actualTerm         Int? // Optional internal schedule term in months captured during raising
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Collateral fields (required for Jadual K products)
  collateralType  String?  // e.g., "Kenderaan", "Hartanah", "Mesin", "Peralatan", etc.
  collateralValue Decimal? @db.Decimal(12, 2) // Estimated value of collateral in RM

  loanChannel LoanChannel @default(ONLINE)

  /// L1 handoff to L2 (set when status becomes PENDING_L2_APPROVAL)
  l1ReviewedAt         DateTime?
  l1ReviewedByMemberId String?
  l1DecisionNote       String?
  /// L2 final credit decision timestamp (approve or reject from L2 queue)
  l2ReviewedAt         DateTime?
  l2ReviewedByMemberId String?
  l2DecisionNote       String?

  // Relations
  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower  Borrower              @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  loan      Loan?
  documents ApplicationDocument[]
  guarantors ApplicationGuarantor[]
  offerRounds LoanApplicationOffer[]
  staffNotes  ApplicationNote[]

  @@index([tenantId])
  @@index([status])
  @@index([borrowerId])
}

model LoanApplicationOffer {
  id              String                    @id @default(cuid())
  tenantId        String
  applicationId   String
  amount          Decimal                   @db.Decimal(12, 2)
  term            Int
  fromParty       LoanApplicationOfferParty
  status          LoanApplicationOfferStatus @default(PENDING)
  createdAt       DateTime                  @default(now())
  resolvedAt      DateTime?

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([applicationId])
  @@index([applicationId, status])
}

model ApplicationGuarantor {
  id            String   @id @default(cuid())
  tenantId      String
  applicationId String
  borrowerId    String
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  borrower    Borrower        @relation(fields: [borrowerId], references: [id], onDelete: Cascade)

  @@unique([applicationId, borrowerId])
  @@index([tenantId])
  @@index([applicationId])
  @@index([borrowerId])
}

model ApplicationDocument {
  id            String   @id @default(cuid())
  tenantId      String
  applicationId String
  filename      String
  originalName  String
  mimeType      String
  size          Int
  path          String
  category      String // Matches key from product.requiredDocuments
  uploadedAt    DateTime @default(now())

  // Relations
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([applicationId])
}

model BorrowerDocument {
  id           String   @id @default(cuid())
  tenantId     String
  borrowerId   String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  category     String // IC_FRONT, IC_BACK, PASSPORT, SSM_CERT, FORM_9, FORM_24, FORM_49, etc.
  uploadedAt   DateTime @default(now())

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([borrowerId])
}

model Loan {
  id               String     @id @default(cuid())
  tenantId         String
  borrowerId       String
  productId        String
  applicationId    String     @unique
  principalAmount  Decimal    @db.Decimal(12, 2)
  interestRate     Decimal    @db.Decimal(5, 2)
  term             Int // in months
  actualInterestRate Decimal? @db.Decimal(5, 2) // Optional internal schedule annual rate for alternate operational view
  actualTerm       Int? // Optional internal schedule term in months for alternate operational view
  disbursementDate DateTime?
  status           LoanStatus @default(PENDING_DISBURSEMENT)
  loanChannel      LoanChannel @default(ONLINE)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Disbursement details
  disbursementReference   String?   // Auto-generated reference (e.g., DIS-20260204-ABC123)
  disbursementProofPath   String?   // Path to proof of disbursement file
  disbursementProofName   String?   // Original filename
  disbursementProofMime   String?   // MIME type
  disbursementProofSize   Int?      // File size in bytes
  disbursementProofAt     DateTime? // When proof was uploaded

  // Completion/discharge fields
  completedAt          DateTime? // When loan was fully paid and completed
  dischargeNotes       String? // Notes added when discharging/completing the loan
  dischargeLetterPath  String? // Path to the generated discharge letter PDF
  dischargeLetterGenAt DateTime? // When discharge letter was generated

  // Agreement document (signed, uploaded by admin before disbursement)
  agreementDate         DateTime? // The agreed disbursement date in the signed agreement (used for schedule calculation)
  agreementPath         String?   // Path to signed agreement file (local or S3) — always the latest version (fully signed for online loans)
  agreementFilename     String?   // Stored filename
  agreementOriginalName String?   // Original uploaded filename
  agreementMimeType     String?   // MIME type (application/pdf)
  agreementSize         Int?      // File size in bytes
  agreementUploadedAt   DateTime? // When agreement was uploaded
  agreementVersion      Int       @default(0) // Version counter for audit trail
  borrowerSignedAgreementPath String? // Online loans only: borrower-only signed PDF (before internal signatures)

  signedAgreementReviewStatus     SignedAgreementReviewStatus @default(NONE)
  signedAgreementReviewedAt       DateTime?
  signedAgreementReviewerMemberId String? // Better Auth user id of reviewer
  signedAgreementReviewNotes      String? // e.g. rejection reason

  // Borrower attestation (video / online meeting) before signing — see AttestationStatus
  attestationStatus                AttestationStatus @default(NOT_STARTED)
  attestationVideoCompletedAt      DateTime?
  attestationVideoWatchedPercent   Int               @default(0)
  attestationMeetingRequestedAt    DateTime?
  /// Current proposed slot window (firm DB hold until accepted/expired/countered)
  attestationProposalStartAt         DateTime?
  attestationProposalEndAt           DateTime?
  attestationProposalDeadlineAt      DateTime?
  attestationProposalSource          AttestationProposalSource?
  attestationBorrowerProposalCount   Int               @default(0)
  attestationAssignedMemberId        String? // TenantMember.id
  attestationMeetingScheduledAt      DateTime?
  attestationMeetingStartAt          DateTime?
  attestationMeetingEndAt            DateTime?
  attestationMeetingLink             String?
  /// Optional instructions when meeting link is set manually (not from Google Calendar)
  attestationMeetingNotes            String?
  attestationGoogleCalendarEventId   String?
  attestationMeetingReminder24hSentAt DateTime?
  attestationCompletedAt             DateTime?
  attestationCancellationReason      AttestationCancellationReason?
  attestationCancelledAt             DateTime?
  attestationCancelledByUserId       String? // User.id (borrower account)

  // Signature field metadata (JSON array of SignatureFieldMeta) from PDF generation
  agreementSignatureFields Json?

  // Stamp certificate (uploaded by admin before disbursement)
  stampCertPath         String?   // Path to stamp certificate file (local or S3)
  stampCertFilename     String?   // Stored filename
  stampCertOriginalName String?   // Original uploaded filename
  stampCertMimeType     String?   // MIME type (application/pdf)
  stampCertSize         Int?      // File size in bytes
  stampCertUploadedAt   DateTime? // When stamp certificate was uploaded
  stampCertVersion      Int       @default(0) // Version counter for audit trail

  // Collateral fields (for Jadual K loans - copied from application on approval)
  collateralType  String?  // e.g., "Kenderaan", "Hartanah", "Mesin", "Peralatan", etc.
  collateralValue Decimal? @db.Decimal(12, 2) // Estimated value of collateral in RM

  // Metrics
  totalLateFees Decimal  @default(0) @db.Decimal(12, 2) // Total late fees charged
  repaymentRate Decimal? @db.Decimal(5, 2) // Percentage of payments made on time

  // Early settlement fields
  earlySettlementDate         DateTime? // When the early settlement was confirmed
  earlySettlementAmount       Decimal?  @db.Decimal(12, 2) // Total settlement amount paid
  earlySettlementDiscount     Decimal?  @db.Decimal(12, 2) // Discount amount given
  earlySettlementNotes        String? // Admin notes for settlement
  earlySettlementWaiveLateFees Boolean  @default(false) // Whether late fees were waived

  // Late fee / default tracking
  readyForDefault   Boolean   @default(false) // True when default period exceeded (admin must manually mark)
  defaultReadyDate  DateTime? // When it became ready for default (UTC)
  arrearsStartDate  DateTime? // When it entered arrears status (UTC)
  arrearsLetterPath String?   // Path to generated arrears letter PDF
  defaultLetterPath String?   // Path to generated default letter PDF

  // Relations
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower         Borrower              @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  product          Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  application      LoanApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  guarantors       LoanGuarantor[]
  scheduleVersions LoanScheduleVersion[]
  transactions     PaymentTransaction[]
  borrowerManualPaymentRequests BorrowerManualPaymentRequest[]
  borrowerEarlySettlementRequests BorrowerEarlySettlementRequest[]
  lateFeeEntries   LateFeeEntry[]
  emailLogs        EmailLog[] // TrueSend email delivery logs
  attestationAssignedMember TenantMember? @relation("AttestationAssignedMember", fields: [attestationAssignedMemberId], references: [id], onDelete: SetNull)
  staffNotes                LoanNote[]
  internalSignatures        LoanInternalSignature[]

  @@index([tenantId])
  @@index([status])
  @@index([borrowerId])
  @@index([borrowerId, disbursementDate, tenantId])
  @@index([tenantId, attestationStatus])
  @@index([attestationProposalDeadlineAt])
}

model LoanGuarantor {
  id                   String   @id @default(cuid())
  tenantId             String
  loanId               String
  borrowerId           String
  order                Int      @default(0)
  name                 String
  borrowerType         String   @default("INDIVIDUAL")
  companyName          String?
  documentType         String   @default("IC")
  icNumber             String
  phone                String?
  email                String?
  address              String?
  agreementGeneratedAt DateTime?
  agreementPath        String?
  agreementFilename    String?
  agreementOriginalName String?
  agreementMimeType    String?
  agreementSize        Int?
  agreementUploadedAt  DateTime?
  agreementVersion     Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loan     Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)

  @@unique([loanId, borrowerId])
  @@index([tenantId])
  @@index([loanId])
  @@index([borrowerId])
}

model LoanScheduleVersion {
  id            String        @id @default(cuid())
  loanId        String
  version       Int
  interestModel InterestModel
  inputs        Json // Store calculation inputs
  outputsHash   String // Hash for integrity verification
  createdAt     DateTime      @default(now())

  // Relations
  loan       Loan            @relation(fields: [loanId], references: [id], onDelete: Cascade)
  repayments LoanRepayment[]

  @@unique([loanId, version])
  @@index([loanId])
}

model LoanRepayment {
  id                String          @id @default(cuid())
  scheduleVersionId String
  dueDate           DateTime
  principal         Decimal         @db.Decimal(12, 2)
  interest          Decimal         @db.Decimal(12, 2)
  totalDue          Decimal         @db.Decimal(12, 2)
  status            RepaymentStatus @default(PENDING)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Late fee tracking (running totals updated by processor)
  lateFeeAccrued Decimal @default(0) @db.Decimal(12, 2) // Total accrued late fees for this repayment
  lateFeesPaid   Decimal @default(0) @db.Decimal(12, 2) // Late fees paid so far

  // Relations
  scheduleVersion LoanScheduleVersion @relation(fields: [scheduleVersionId], references: [id], onDelete: Cascade)
  allocations     PaymentAllocation[]
  lateFeeEntries  LateFeeEntry[]

  @@index([scheduleVersionId])
  @@index([dueDate])
  @@index([status])
  @@index([status, dueDate])
}

// A payment transaction represents a single payment made by a borrower
// It can be allocated across multiple scheduled repayments (for prepayments/spillover)
model PaymentTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  loanId      String
  totalAmount Decimal  @db.Decimal(12, 2) // Total amount paid in this transaction
  paymentType String   @default("REGULAR") // REGULAR or EARLY_SETTLEMENT
  reference   String? // Payment reference (e.g., bank transfer ref)
  notes       String?
  paymentDate DateTime // When the payment was made
  createdAt   DateTime @default(now())

  // Generated receipt (stored on creation)
  receiptNumber String?  @unique // e.g., "RCP-20260204-001"
  receiptPath   String? // Path to stored PDF (local or S3)
  receiptGenAt  DateTime? // When receipt was generated

  // Proof of payment uploaded by admin
  proofFilename     String?
  proofOriginalName String?
  proofMimeType     String?
  proofSize         Int?
  proofPath         String?
  proofUploadedAt   DateTime?

  // Relations
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loan        Loan                @relation(fields: [loanId], references: [id], onDelete: Cascade)
  allocations PaymentAllocation[]
  borrowerManualPaymentRequest BorrowerManualPaymentRequest?
  borrowerEarlySettlementRequest BorrowerEarlySettlementRequest?

  @@index([tenantId])
  @@index([loanId])
  @@index([receiptNumber])
}

/// Borrower-initiated early settlement; admin executes the same settlement logic as direct confirm
model BorrowerEarlySettlementRequest {
  id     String @id @default(cuid())
  tenantId   String
  loanId     String
  borrowerId String

  status BorrowerEarlySettlementRequestStatus @default(PENDING)

  snapshotEligible             Boolean
  snapshotReason               String?
  snapshotTotalSettlement      Decimal? @db.Decimal(12, 2)
  snapshotTotalWithoutLateFees Decimal? @db.Decimal(12, 2)
  snapshotOutstandingLateFees  Decimal? @db.Decimal(12, 2)
  snapshotDiscountAmount       Decimal? @db.Decimal(12, 2)
  snapshotRemainingPrincipal   Decimal? @db.Decimal(12, 2)
  snapshotRemainingInterest    Decimal? @db.Decimal(12, 2)
  snapshotUnpaidInstallments   Int?

  borrowerNote String? @db.VarChar(1000)
  reference    String? @db.VarChar(200)

  rejectionReason     String?
  reviewedAt          DateTime?
  reviewedByMemberId  String?
  paymentTransactionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant               Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loan                 Loan                               @relation(fields: [loanId], references: [id], onDelete: Cascade)
  borrower             Borrower                           @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  paymentTransaction   PaymentTransaction?                @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([loanId])
  @@index([borrowerId])
  @@index([status])
  @@index([tenantId, status])
}

/// Borrower-submitted bank transfer; ledger updates only after admin approval
model BorrowerManualPaymentRequest {
  id            String                           @id @default(cuid())
  tenantId      String
  loanId        String
  borrowerId    String
  amount        Decimal                          @db.Decimal(12, 2)
  reference     String
  status        BorrowerManualPaymentRequestStatus @default(PENDING)
  rejectionReason String?
  receiptPath   String?
  receiptFilename String?
  receiptOriginalName String?
  receiptMimeType String?
  receiptSize   Int?
  paymentTransactionId String? @unique
  reviewedAt    DateTime?
  reviewedByMemberId String?
  createdAt     DateTime                         @default(now())
  updatedAt     DateTime                         @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loan     Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([loanId])
  @@index([borrowerId])
  @@index([status])
  @@index([tenantId, status])
}

model PaymentAllocation {
  id            String   @id @default(cuid())
  transactionId String? // Optional for backward compatibility with existing data
  repaymentId   String
  amount        Decimal  @db.Decimal(12, 2)
  allocatedAt   DateTime @default(now())

  // Legacy fields (kept for backward compatibility, will be removed in future)
  reference String?
  notes     String?

  // Late fee and early payment tracking
  lateFee        Decimal? @db.Decimal(12, 2) // Late fee charged for this allocation
  isEarlyPayment Boolean  @default(false) // Whether this was an early/advance payment

  // Relations
  transaction PaymentTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  repayment   LoanRepayment       @relation(fields: [repaymentId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([repaymentId])
}

// ============================================
// Internal staff notes (admin-only; not borrower-visible)
// ============================================

model BorrowerNote {
  id                String   @id @default(cuid())
  tenantId          String
  borrowerId        String
  body              String   @db.Text
  createdByMemberId String?
  createdAt         DateTime @default(now())

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower  Borrower      @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  createdBy TenantMember? @relation(fields: [createdByMemberId], references: [id], onDelete: SetNull)

  @@index([tenantId, borrowerId, createdAt(sort: Desc)])
  @@map("borrower_notes")
}

model ApplicationNote {
  id                String   @id @default(cuid())
  tenantId          String
  applicationId     String
  body              String   @db.Text
  createdByMemberId String?
  createdAt         DateTime @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdBy   TenantMember?   @relation(fields: [createdByMemberId], references: [id], onDelete: SetNull)

  @@index([tenantId, applicationId, createdAt(sort: Desc)])
  @@map("application_notes")
}

model LoanNote {
  id                String   @id @default(cuid())
  tenantId          String
  loanId            String
  body              String   @db.Text
  createdByMemberId String?
  createdAt         DateTime @default(now())

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loan      Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  createdBy TenantMember? @relation(fields: [createdByMemberId], references: [id], onDelete: SetNull)

  @@index([tenantId, loanId, createdAt(sort: Desc)])
  @@map("loan_notes")
}

// ============================================
// Compliance Models
// ============================================

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  memberId     String? // TenantMember who performed the action
  action       String
  entityType   String
  entityId     String
  previousData Json?
  newData      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  // Relations
  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member TenantMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@index([action])
}

// ============================================
// File Storage Models
// ============================================

model File {
  id           String   @id @default(cuid())
  tenantId     String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  category     String // e.g., 'invoices', 'receipts', 'uploads', 'reports'
  uploadedAt   DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([category])
}

// ============================================
// Notification Models
// ============================================

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  type      String // e.g., 'email', 'whatsapp'
  recipient String
  subject   String?
  body      String
  status    String    @default("pending") // pending, sent, failed
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model TenantNotificationSetting {
  id                String   @id @default(cuid())
  tenantId          String
  notificationKey   String
  channel           String   // email, in_app, push
  enabled           Boolean  @default(true)
  updatedByMemberId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, notificationKey, channel])
  @@index([tenantId, notificationKey])
}

model BorrowerNotification {
  id              String   @id @default(cuid())
  tenantId        String
  borrowerId      String
  category        String
  notificationKey String
  title           String
  body            String
  deepLink        String?
  sourceType      String?
  sourceId        String?
  metadata        Json?
  readAt          DateTime?
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower   Borrower                      @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  deliveries BorrowerNotificationDelivery[]

  @@index([tenantId, borrowerId, createdAt(sort: Desc)])
  @@index([tenantId, sourceType, sourceId])
  @@index([borrowerId, readAt])
}

model BorrowerNotificationDelivery {
  id                     String   @id @default(cuid())
  tenantId               String
  borrowerId             String?
  borrowerNotificationId String?
  channel                String   // email, in_app, push
  provider               String?
  providerMessageId      String?
  tokenSnapshot          String?
  status                 String   @default("pending")
  errorMessage           String?
  sentAt                 DateTime?
  deliveredAt            DateTime?
  openedAt               DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower             Borrower?             @relation(fields: [borrowerId], references: [id], onDelete: SetNull)
  borrowerNotification BorrowerNotification? @relation(fields: [borrowerNotificationId], references: [id], onDelete: SetNull)

  @@index([tenantId, channel, status, createdAt(sort: Desc)])
  @@index([borrowerNotificationId])
  @@index([borrowerId, createdAt(sort: Desc)])
}

model BorrowerPushDevice {
  id         String   @id @default(cuid())
  tenantId   String
  borrowerId String
  userId     String?
  token      String
  platform   String
  provider   String   @default("expo")
  appId      String?
  deviceName String?
  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tenantId, token])
  @@index([tenantId, borrowerId])
  @@index([tenantId, isActive])
  @@index([borrowerId, isActive])
}

model NotificationCampaign {
  id                String   @id @default(cuid())
  tenantId          String
  title             String
  body              String
  deepLink          String?
  audienceType      String
  channels          String[] @default([])
  status            String   @default("DRAFT")
  recipientCount    Int      @default(0)
  scheduledAt       DateTime?
  publishedAt       DateTime?
  createdByMemberId String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt(sort: Desc)])
}

// ============================================
// Event Outbox (for internal admin sync)
// ============================================

model OutboxEvent {
  id             String      @id @default(cuid())
  tenantId       String
  eventType      String
  payload        Json
  idempotencyKey String      @unique
  status         EventStatus @default(PENDING)
  attempts       Int         @default(0)
  lastAttemptAt  DateTime?
  sentAt         DateTime?
  createdAt      DateTime    @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tenantId])
}

// ============================================
// Late Fee Models
// ============================================

// Immutable daily log: one row per repayment per day of accrual
model LateFeeEntry {
  id                String   @id @default(cuid())
  tenantId          String
  loanId            String
  repaymentId       String
  accrualDate       DateTime // UTC representation of the Malaysia business day
  daysOverdue       Int      // Number of days overdue at time of accrual
  outstandingAmount Decimal  @db.Decimal(12, 2) // Amount in arrears that fee was calculated on
  dailyRate         Decimal  @db.Decimal(10, 8) // Daily rate used (latePaymentRate / 365 / 100)
  feeAmount         Decimal  @db.Decimal(12, 2) // Fee charged for this day
  createdAt         DateTime @default(now())

  // Relations
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loan      Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  repayment LoanRepayment @relation(fields: [repaymentId], references: [id], onDelete: Cascade)

  @@unique([repaymentId, accrualDate]) // Prevents double-charging per repayment per day
  @@index([tenantId])
  @@index([loanId])
  @@index([repaymentId])
  @@index([accrualDate])
}

// ============================================
// TrueSend Email Log (delivery tracking via Resend webhooks)
// ============================================

model EmailLog {
  id              String    @id @default(cuid())
  tenantId        String
  loanId          String?
  borrowerId      String?
  emailType       String // PAYMENT_REMINDER, LATE_PAYMENT, ARREARS_NOTICE, DEFAULT_NOTICE, DISBURSEMENT, COMPLETION
  recipientEmail  String
  recipientName   String?
  subject         String
  resendMessageId String? // Resend's email ID for webhook matching
  status          String    @default("pending") // pending, sent, delivered, bounced, failed, delayed, complained
  attachmentPath  String? // Path to attached PDF
  failureReason   String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  lastEventAt     DateTime?
  resentAt        DateTime? // Track last resend time (1x/day limit)
  resentCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loan     Loan?     @relation(fields: [loanId], references: [id])
  borrower Borrower? @relation(fields: [borrowerId], references: [id])

  @@index([tenantId])
  @@index([loanId])
  @@index([resendMessageId])
  @@index([emailType])
  @@index([status])
}

// Idempotency records for payment submission endpoints
model PaymentIdempotency {
  id             String   @id @default(cuid())
  tenantId       String
  endpoint       String
  idempotencyKey String
  requestHash    String
  status         String   @default("PROCESSING") // PROCESSING, COMPLETED, FAILED
  responseStatus Int?
  responseBody   Json?
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, endpoint, idempotencyKey])
  @@index([tenantId, createdAt])
  @@index([status])
}

// Deterministic reminder de-duplication for payment reminders
model PaymentReminderDispatch {
  id              String   @id @default(cuid())
  tenantId        String
  loanId          String
  repaymentId     String
  reminderType    String   // DUE_IN_3_DAYS, DUE_IN_1_DAY, DUE_ON_DAY, ...
  reminderDateMYT DateTime // Start of reminder day in MYT, stored as UTC
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, loanId, repaymentId, reminderType, reminderDateMYT])
  @@index([tenantId, reminderDateMYT])
  @@index([loanId, repaymentId])
}

// Deterministic de-duplication for late payment notices
model LatePaymentNoticeDispatch {
  id            String   @id @default(cuid())
  tenantId      String
  loanId        String
  noticeType    String   // LATE_3_DAYS, LATE_7_DAYS, ...
  noticeDateMYT DateTime // Start of notice day in MYT, stored as UTC
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, loanId, noticeType, noticeDateMYT])
  @@index([tenantId, noticeDateMYT])
  @@index([loanId])
}

// ============================================
// TrueIdentity Verification Models
// ============================================

model TrueIdentitySession {
  id             String    @id @default(cuid())
  tenantId       String
  borrowerId     String
  directorId     String?   // When set, verification is for this director (corporate KYC)
  adminSessionId String    @unique
  onboardingUrl  String
  status         String    @default("pending")
  result         String?
  rejectMessage  String?
  expiresAt      DateTime
  requestPayload Json?
  verificationDocumentUrls Json? // { icFrontUrl?, icBackUrl?, selfieUrl?, verificationDetailUrl? } from Admin
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  borrower Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([borrowerId])
  @@index([directorId])
}

model TrueIdentityWebhookEvent {
  id               String    @id @default(cuid())
  tenantId         String?
  idempotencyKey   String    @unique
  rawPayload       Json
  signatureHeader String?
  timestampHeader String?
  status           String    @default("PENDING")
  processedAt      DateTime?
  usageRecordedAt  DateTime?  // Set before recordVerificationComplete to make usage increment idempotent on retry
  errorMessage     String?
  createdAt        DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model TrueIdentityUsageDaily {
  id        String   @id @default(cuid())
  tenantId  String
  usageDate DateTime
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usageDate])
  @@index([tenantId])
}

// Audit trail for each cron / manual late fee processing run
model LateFeeProcessingLog {
  id               String   @id @default(cuid())
  tenantId         String?  // null = system-wide run across all tenants
  processedAt      DateTime @default(now())
  trigger          String   // "CRON" | "MANUAL"
  status           String   // "SUCCESS" | "FAILED"
  loansProcessed   Int      @default(0)
  feesCalculated   Int      @default(0)
  totalFeeAmount   Decimal  @default(0) @db.Decimal(12, 2)
  arrearsLetters   Int      @default(0)
  processingTimeMs Int      @default(0)
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([processedAt])
  @@index([trigger])
  @@index([tenantId, processedAt])
}

// ============================================
// PKI Signing — Staff / Internal Signer Models
// ============================================

model StaffSigningProfile {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  icNumber      String
  fullName      String
  email         String
  phone         String?
  nationality   String   @default("MY")
  documentType  String   @default("MYKAD") // MYKAD, PASSPORT
  designation   String?  // e.g. "Director", "Authorised Signatory"
  certSerialNo  String?
  certStatus    String?  // Valid, Expired, Revoked, null
  certValidFrom DateTime?
  certValidTo   DateTime?
  kycComplete   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents StaffDocument[]
  kycSessions StaffKycSession[]

  @@unique([tenantId, userId])
  @@unique([tenantId, icNumber])
  @@index([tenantId])
}

model StaffDocument {
  id           String   @id @default(cuid())
  tenantId     String
  profileId    String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  category     String   // IC_FRONT, IC_BACK, PASSPORT, SELFIE_LIVENESS
  uploadedAt   DateTime @default(now())

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile StaffSigningProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([tenantId])
}

model StaffKycSession {
  id                String   @id @default(cuid())
  tenantId          String
  profileId         String
  externalSessionId String   @unique
  onboardingUrl     String
  expiresAt         DateTime?
  status            String   @default("pending") // pending, processing, completed, expired, failed
  result            String?  // approved, rejected when status=completed
  rejectMessage     String?
  lastWebhookAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile StaffSigningProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([profileId])
}

model LoanInternalSignature {
  id               String   @id @default(cuid())
  loanId           String
  tenantId         String
  role             String   // COMPANY_REP, WITNESS
  userId           String
  signerName       String
  signerIc         String
  signedAt         DateTime @default(now())
  signaturePath    String?
  agreementVersion Int
  pageNo           Int
  x1               Float
  y1               Float
  x2               Float
  y2               Float

  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([loanId, role])
  @@index([loanId])
  @@index([tenantId])
}
