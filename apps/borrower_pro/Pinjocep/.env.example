# Pinjocep environment variables
# Copy to .env and fill in values

# App URL (used by Better Auth)
NEXT_PUBLIC_APP_URL=http://localhost:3008

# Local dev only: skip mandatory passkey / TOTP security-setup redirect. Do not set in production.
# NEXT_PUBLIC_SKIP_SECURITY_SETUP_REDIRECT=true

# Backend API (for future API calls)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4001

# Auth secret - MUST match backend_pro BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=dev-secret-change-in-production-32-chars-minimum

# Database - same as backend_pro (port 5434)
DATABASE_URL=postgresql://kredit_pro:kredit_pro_dev@localhost:5434/kredit_pro_dev

# Resend (auth emails: verification, password reset, change email)
# RESEND_API_KEY=

# --- Dev-only (NODE_ENV=development): faster org-invite E2E without email verification ---
# Do NOT set in production.
# Skip Better Auth "verified email required" when accepting an organization invitation.
# BORROWER_AUTH_DEV_SKIP_INVITE_EMAIL_VERIFICATION=true
# Skip "must verify email before sign-in" (so new test users can sign in immediately).
# BORROWER_AUTH_DEV_SKIP_SIGNIN_EMAIL_VERIFICATION=true
