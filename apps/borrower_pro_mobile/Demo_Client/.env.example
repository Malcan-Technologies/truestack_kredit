# Copy to `.env` for local development. Expo inlines `EXPO_PUBLIC_*` at bundle time.

# backend_pro base URL (no trailing slash) — replaces Next.js `/api/proxy` for native.
EXPO_PUBLIC_BACKEND_URL=http://localhost:4001

# Borrower web origin where Better Auth lives (see apps/borrower_pro/Demo_Client).
EXPO_PUBLIC_AUTH_BASE_URL=http://localhost:3006

# Optional override for the passkey relying-party ID.
# Leave blank to derive it from EXPO_PUBLIC_AUTH_BASE_URL.
# For native iOS/Android passkeys, this must be an HTTPS hostname, not localhost.
EXPO_PUBLIC_PASSKEY_RP_ID=

# Matches Pro deployment CLIENT_ID where relevant.
EXPO_PUBLIC_CLIENT_ID=demo-client
