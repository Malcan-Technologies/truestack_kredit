# Copy to `.env` for local development. Expo inlines `EXPO_PUBLIC_*` at bundle time.

# backend_pro base URL (no trailing slash) — replaces Next.js `/api/proxy` for native.
EXPO_PUBLIC_BACKEND_URL=http://localhost:4001

# Borrower web origin where Better Auth lives (see apps/borrower_pro/Demo_Client).
EXPO_PUBLIC_AUTH_BASE_URL=http://localhost:3006

# --- Android APK / physical device ---
# `localhost` here is the phone itself, so API calls fail unless you use tunneled HTTPS URLs
# (or your machine's LAN IP). EXPO_PUBLIC_* is baked in at build time — change .env then rebuild.
#
# EXPO_PUBLIC_BACKEND_URL=https://dev-tunnel-4001.truestack.my
# EXPO_PUBLIC_AUTH_BASE_URL=https://dev-tunnel-3006.truestack.my
# Extra dev ports on the same tunnel: https://dev-tunnel-PORT.truestack.my -> http://127.0.0.1:PORT
# for PORT in 3000 3001 3002 3003 3004 3005 3006 4001.
# Match backend_pro: BACKEND_PRO_PUBLIC_URL, BORROWER_WEB_URL, BETTER_AUTH_TRUSTED_ORIGINS.
# Cloudflare Tunnel example: map https://dev-tunnel-PORT.truestack.my -> http://127.0.0.1:PORT
# (see `.env.tunnel.local` if present).

# --- Android emulator (Windows + WSL/Docker) ---
# Inside the emulator, `localhost` is the emulator itself, not your PC — sign-in fails with
# "Network request failed" unless ports are forwarded. From Demo_Client run:
#   npm run reverse:adb
# (emulator must be running; repeats after emulator restart). Or use `npm run dev:android`.
# That maps 127.0.0.1:8081/4001/3006 on the device to the same ports on the Windows host.
# Your stack must listen on Windows localhost (Docker Desktop / WSL mirroring usually does).
# Alternative without adb: set URLs to http://10.0.2.2:PORT (emulator alias for host loopback).
# iOS Simulator: localhost in `.env` is usually fine (shares the Mac network stack).

# Matches Pro deployment CLIENT_ID where relevant.
EXPO_PUBLIC_CLIENT_ID=demo-client

# Metro dev server hostname for the native dev client (fixes "Unable to load script" on Android).
# Recommended default for WSL2 + Android emulator on Windows: use `127.0.0.1` and rely on
# `adb reverse tcp:8081 tcp:8081` (Expo CLI runs this automatically; you can also run it by hand).
# The WSL IP (172.x) is unreachable from the emulator, and Windows does not always forward
# localhost:8081 to WSL, so 10.0.2.2 can also fail. 127.0.0.1 + adb reverse is the most reliable.
# Physical device on USB: same — keep 127.0.0.1 and run `adb reverse tcp:8081 tcp:8081`.
# Physical device on Wi-Fi: set this to your PC's LAN IP (not the WSL-only 172.x address).
REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1
